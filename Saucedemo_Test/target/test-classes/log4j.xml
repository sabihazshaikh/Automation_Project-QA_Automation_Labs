<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
	<Appenders>
		<Console name="Console" target="SYSTEM_OUT">
			<PatternLayout pattern="%d{HH:mm:ss} [%p] %m%n" />
		</Console>

		<File name="File" fileName="logs/automation.log" append="false">
			<PatternLayout
				pattern="%d{yyyy-MM-dd HH:mm:ss} [%p] %m%n" />
		</File>
	</Appenders>

	<Loggers>
		<Root level="info">
			<AppenderRef ref="Console" />
			<AppenderRef ref="File" />
		</Root>

	</Loggers>

</Configuration>